      "num": "01 · the shape",
      "heading": "Busy is not diagnostic",
      "blocks": [
        {
          "type": "prose",
          "html": "<p class=\"body\">Managers hear \"busy\" from everyone. Useful context sounds more like: this decision is blocked, this project has hidden risk, this scope no longer fits, or this work is draining the wrong battery.</p>"
        },
        {
          "type": "terminal",
          "title": "1:1 · better signal",
          "caption": "The useful signal is usually already there.",
