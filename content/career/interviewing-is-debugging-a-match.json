  "beats": [
    {
      "num": "01 · the shape",
      "heading": "The offer is not the whole answer",
      "blocks": [
        {
          "type": "prose",
          "html": "<p class=\"body\">A role can have good compensation and still be wrong for your energy, growth, manager, schedule, or values. You need questions that reveal the day-to-day system.</p>"
        },
        {
          "type": "terminal",
          "title": "interview · questions",
          "caption": "The useful signal is usually already there.",
          "lines": [
            {
              "t": "How are incidents handled after hours?",
              "c": ""
            },
            {
              "t": "What changed in the last performance cycle?",
              "c": ""
            },
            {
              "t": "What would make this hire successful in 90 days?",
              "c": ""
            }
          ]
        },
        {
          "type": "graph",
          "center": "growth loop",
          "nodes": [
            "work",
            "evidence",
            "feedback",
            "manager",
            "peers",
            "next bet"
          ],
          "caption": "Career systems are still systems. Pull out evidence and everything gets harder to debug.",
          "action": "hide the receipts",
          "idle": "career signal visible",
          "running": "impact getting fuzzy...",
          "done": "6 career signals lost context"
        }
      ]
    },
    {
      "num": "02 · the move",
      "heading": "Ask for examples",
      "blocks": [
        {
          "type": "prose",
          "html": "<p class=\"body\">Specific stories beat brand claims. Ask about a recent conflict, launch, missed deadline, promotion, or incident. Real examples reveal operating habits.</p>"
        },
        {
          "type": "code",
          "file": "interview-notes.md",
          "code": "Signal: manager gave concrete examples\nConcern: roadmap changed weekly, no prioritization method\nFollow-up: ask future teammates about review load",
          "caption": "Notes keep excitement from overwriting evidence."
        }
      ]
    },
    {
      "num": "03 · the check",
      "heading": "Evaluate both directions",
      "blocks": [
        {
          "type": "prose",
          "html": "<p class=\"body\">You are being assessed, but so is the company. A healthy interview process leaves you with more clarity, not just more anxiety.</p>"
        },
        {
