  "beats": [
    {
      "num": "01 · the shape",
      "heading": "Teams drown in plausible work",
      "blocks": [
        {
          "type": "prose",
          "html": "<p class=\"body\">Most backlog items are not obviously dumb. That is what makes them dangerous. Without a strategy, every request gets argued on its own tiny island.</p>"
        },
        {
          "type": "terminal",
          "title": "roadmap · triage",
          "caption": "The useful signal is usually already there.",
          "lines": [
            {
              "t": "yes: improve activation checkout",
              "c": ""
            },
            {
              "t": "no: rebuild settings for aesthetics",
              "c": "dim"
            },
            {
              "t": "later: admin bulk tools after support volume proves it",
              "c": ""
            }
          ]
        },
        {
          "type": "graph",
          "center": "decision",
          "nodes": [
            "context",
            "owner",
            "risk",
            "feedback",
            "scope",
            "followup"
          ],
          "caption": "Leadership bugs are system bugs too. Pull context out and the team graph starts wobbling.",
          "action": "remove context",
          "idle": "team has a map",
          "running": "watching ambiguity spread...",
          "done": "6 leadership signals went red"
        }
      ]
    },
    {
      "num": "02 · the move",
      "heading": "Write the tradeoff down",
      "blocks": [
        {
          "type": "prose",
          "html": "<p class=\"body\">A useful strategy names the audience, the constraint, the bet, and the things the team will not do while the bet is active.</p>"
        },
        {
          "type": "code",
          "file": "strategy.md",
          "code": "Bet: reduce checkout uncertainty for first-time customers\nConstraint: no net-new payment providers this cycle\nNo: settings redesign, dashboard polish, referral revamp",
          "caption": "The \"no\" list protects the \"yes\" list."
        }
      ]
    },
    {
      "num": "03 · the check",
      "heading": "Review against outcomes",
      "blocks": [
        {
          "type": "prose",
          "html": "<p class=\"body\">Strategy needs evidence. Pick leading indicators and revisit the bet before it becomes team folklore.</p>"
        },
        {
          "type": "lab",
          "title": "team clarity switchboard",
