    {
      "num": "04 · the takeaway",
      "heading": "The guardrails are the product",
      "blocks": [
        {
          "type": "prose",
          "html": "<p class=\"body\">Users do not just want the agent to act. They want to trust it while it acts. That trust comes from limits, receipts, and graceful refusal.</p>"
        },
