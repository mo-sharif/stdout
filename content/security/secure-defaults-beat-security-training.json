  "slug": "secure-defaults-beat-security-training",
  "title": "Secure defaults beat security training",
  "category": "security",
  "kicker": "Secure by design",
  "hook": "Training helps. Defaults help even when everyone is tired, rushed, or new.",
  "readMinutes": 5,
