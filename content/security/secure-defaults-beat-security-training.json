              "to": 0,
              "label": "copy-pasted security folklore"
            }
          ]
        }
      ]
    },
    {
      "num": "04 · the takeaway",
      "heading": "Make the safe path boring",
      "blocks": [
        {
          "type": "prose",
          "html": "<p class=\"body\">A secure culture is not only people knowing the right thing. It is systems that make the right thing the normal thing.</p>"
        },
