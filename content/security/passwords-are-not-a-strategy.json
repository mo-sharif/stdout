              "c": ""
            },
            {
              "t": "step-up challenge required",
              "c": "err"
            }
          ]
        },
        {
          "type": "graph",
          "center": "trust boundary",
          "nodes": [
            "input",
            "authn",
            "authz",
            "secrets",
            "deps",
            "egress"
          ],
          "caption": "Security gets real when the trust boundaries light up. Poke it and see what has to hold.",
          "action": "poke the boundary",
          "idle": "controls quiet",
          "running": "attack path lighting up...",
          "done": "6 security edges need review"
        }
      ]
    },
    {
      "num": "02 · the move",
      "heading": "Protect the recovery path",
      "blocks": [
        {
          "type": "prose",
          "html": "<p class=\"body\">Account recovery deserves the same design attention as login. If support can bypass every control with a weak process, attackers will aim there.</p>"
        },
        {
          "type": "code",
          "file": "auth-policy.yml",
          "code": "mfa_required: true\npassword_breach_check: true\nrecovery_requires:\n  - verified_email\n  - recent_device_or_support_review",
          "caption": "Authentication policy is more than a regex."
        }
      ]
    },
    {
      "num": "03 · the check",
      "heading": "Throttle guesses and watch anomalies",
      "blocks": [
        {
          "type": "prose",
          "html": "<p class=\"body\">Rate limits, lockouts, device signals, and alerts make credential attacks noisier and less profitable.</p>"
        },
        {
          "type": "lab",
          "title": "security control lab",
