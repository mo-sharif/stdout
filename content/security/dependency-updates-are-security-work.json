  "beats": [
    {
      "num": "01 · the shape",
      "heading": "Dependencies do not stay still",
      "blocks": [
        {
          "type": "prose",
          "html": "<p class=\"body\">Every package brings code, maintainers, release habits, transitive dependencies, and vulnerability history. Ignoring updates just saves the risk for a worse week.</p>"
        },
        {
          "type": "terminal",
          "title": "npm · audit signal",
