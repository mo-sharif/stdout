            "tests",
            "API",
            "data",
            "logs",
            "review",
            "deploy"
          ],
          "caption": "A tiny patch rarely touches only one thing. Push it and watch the review surface appear.",
          "action": "ship the diff",
          "idle": "change looks calm",
          "running": "checking blast radius...",
          "done": "6 engineering checks touched"
