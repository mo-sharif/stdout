  "beats": [
    {
      "num": "01 · the shape",
      "heading": "Distance is latency",
      "blocks": [
        {
          "type": "prose",
          "html": "<p class=\"body\">If every image, script, and page has to travel from one origin server, users far away pay for geography. A CDN stores copies at edge locations so repeated requests take a shorter path.</p>"
        },
        {
          "type": "terminal",
          "title": "curl · edge hit",
          "caption": "The useful signal is usually already there.",
          "lines": [
            {
              "t": "$ curl -I https://static.example/app.css",
              "c": "pr"
            },
            {
              "t": "cf-cache-status: HIT",
              "c": ""
            },
            {
              "t": "age: 86400",
              "c": ""
            }
          ]
        },
        {
          "type": "graph",
          "center": "request",
          "nodes": [
            "client",
            "edge",
            "API",
            "queue",
            "db",
            "cache"
