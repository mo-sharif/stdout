  "beats": [
    {
      "num": "01 · the shape",
      "heading": "Synchronous work breaks at the edge",
      "blocks": [
        {
          "type": "prose",
          "html": "<p class=\"body\">When every request tries to do every job immediately, spikes become timeouts. A queue lets the user-facing path accept work quickly and lets workers drain it at a controlled pace.</p>"
        },
        {
