              "c": "err"
            },
            {
              "t": "oldest job age: 73s",
              "c": ""
            },
            {
              "t": "workers: 12",
              "c": ""
            }
          ]
        }
      ]
    },
    {
      "num": "02 · the move",
      "heading": "Design for waiting",
      "blocks": [
        {
          "type": "prose",
          "html": "<p class=\"body\">Queued work needs idempotency, retries, dead-letter handling, progress visibility, and a clear answer to how old is too old.</p>"
        },
        {
          "type": "code",
          "file": "jobs/send-receipt.js",
          "code": "await queue.publish(\"send_receipt\", {\n  idempotencyKey: order.id,\n  orderId: order.id,\n  attempt: 0\n});",
          "caption": "Idempotency keeps retries from becoming duplicate side effects."
        }
      ]
    },
    {
      "num": "03 · the check",
      "heading": "Watch age, not just depth",
      "blocks": [
        {
          "type": "prose",
          "html": "<p class=\"body\">Queue depth tells you how much work exists. Oldest job age tells you what users are experiencing.</p>"
        },
        {
          "type": "stats",
          "items": [
            {
              "to": 2,
